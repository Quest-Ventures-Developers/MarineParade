# Google Drive
FROM_FOLDER=01 Events
GOOGLE_CREDENTIALS_JSON=./credentials.json

# Import target and state
TO_FOLDER=./export/zoepham
TEMP_FOLDER=./tmp/downloads
STATE_FILE=./zoepham_imported_state.json
RESIZE_PERCENT=70
TIMEZONE=Asia/Ho_Chi_Minh

# Behavior
DRY_RUN=false
OVERWRITE_EXISTING=false
LOG_LEVEL=INFO
CRAWL_LIMIT=0
RUN_MODE=live
